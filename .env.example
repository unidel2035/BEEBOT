# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API
GROQ_API_KEY=your_groq_api_key_here

# Model settings
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Knowledge base
FAISS_INDEX_PATH=data/processed/index.faiss
CHUNKS_PATH=data/processed/chunks.json

# Bot settings
MAX_CONTEXT_CHUNKS=5
MAX_RESPONSE_LENGTH=4096

# Telegram ID пчеловода для уведомлений о новых заказах
BEEKEEPER_CHAT_ID=your_beekeeper_telegram_id_here

# Telegram ID администратора для аналитики (если не задан — используется BEEKEEPER_CHAT_ID)
ADMIN_CHAT_ID=your_admin_telegram_id_here

# UDS (система лояльности)
UDS_API_KEY=your_uds_api_key_here
UDS_COMPANY_ID=your_uds_company_id_here

# Delivery — СДЭК API v2 (OAuth 2.0)
CDEK_CLIENT_ID=your_cdek_client_id_here
CDEK_CLIENT_SECRET=your_cdek_client_secret_here

# Delivery — Почта России API
POCHTA_TOKEN=your_pochta_token_here
POCHTA_KEY=your_pochta_key_here

# Delivery — общее
SENDER_CITY=Москва

# YouTube Data API (опционально — для автообновления базы знаний)
# Получить ключ: console.cloud.google.com → YouTube Data API v3
# YOUTUBE_API_KEY=your_youtube_api_key_here
# YOUTUBE_CHANNEL_HANDLE=@a.dmitrov

# Integram CRM
INTEGRAM_URL=https://ai2o.ru
INTEGRAM_LOGIN=your_integram_login_here
INTEGRAM_PASSWORD=your_integram_password_here
INTEGRAM_DB=your_integram_db_here

# Groq API proxy (необязательно — для обхода блокировки IP)
# GROQ_BASE_URL=http://localhost:8990

# Telegram SOCKS5 proxy (необязательно — если VPS блокирует api.telegram.org)
# Настройка: запустить tg-socks.service на hive + добавить в groq-tunnel.service -R 9150:localhost:9150
# TG_SOCKS_PROXY=socks5://localhost:9150

# Веб-панель (обязательно!)
WEB_PASSWORD=your_strong_password_here
# WEB_SECRET=your_jwt_secret_here  # если не задан — генерируется при каждом запуске
# WEB_CORS_ORIGINS=http://185.233.200.13:8088,http://localhost:5173
