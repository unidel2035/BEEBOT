# ---- Frontend build stage ----
FROM node:22-alpine AS frontend-build

WORKDIR /app/web

COPY web/package.json ./
RUN npm install

COPY web/ ./
RUN npm run build

# ---- Backend + static stage ----
FROM python:3.12-slim

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies (FastAPI subset — no torch/faiss needed for web)
COPY requirements.txt .
RUN pip install --no-cache-dir \
    fastapi==0.115.12 \
    "uvicorn[standard]==0.34.0" \
    python-multipart==0.0.20 \
    "python-jose[cryptography]==3.3.0" \
    httpx==0.28.1 \
    pydantic==2.11.1 \
    python-dotenv==1.2.2

# Copy application source (only web-related modules)
COPY src/ src/

# Copy built Vue frontend to serve as static files
COPY --from=frontend-build /app/web/dist /app/web/dist

# Serve static files + API
CMD ["uvicorn", "src.web.server:app", "--host", "0.0.0.0", "--port", "8080"]
